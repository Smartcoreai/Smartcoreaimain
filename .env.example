# Copy to .env.local and fill in your values
# NEVER commit .env.local to git

# =========================================
# REQUIRED — AI
# =========================================

# Anthropic API key (for Aria chatbot)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# =========================================
# REQUIRED — Email
# =========================================

# Resend API key (for contact form emails)
RESEND_API_KEY=re_YOUR_KEY_HERE

# Recipient address for contact form submissions
CONTACT_EMAIL=hei@ekspedenten.no

# =========================================
# REQUIRED — Admin access
# =========================================

# Password for /api/leads admin endpoints (GET, DELETE, PATCH)
# Set in Vercel Dashboard — minimum 16 random characters
ADMIN_PASSWORD=SET_A_STRONG_RANDOM_PASSWORD_IN_VERCEL

# =========================================
# REQUIRED (production) — Upstash Redis (rate limiting)
# =========================================

# Create a free database at upstash.com → Redis → copy REST URL + token
# Without these, rate limiting is disabled (fail-open) — fine for local dev
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# =========================================
# OPTIONAL — GoHighLevel CRM
# =========================================

# GHL API key and location ID (for lead routing to CRM pipeline)
GHL_API_KEY=pit-YOUR_KEY_HERE
GHL_LOCATION_ID=YOUR_LOCATION_ID_HERE

# GHL pipeline and stage IDs (find in GHL → Opportunities → your pipeline URL)
GHL_PIPELINE_ID=YOUR_PIPELINE_ID_HERE
GHL_STAGE_ID=YOUR_STAGE_ID_HERE
